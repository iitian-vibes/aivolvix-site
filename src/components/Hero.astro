---
import { hero } from "../content/copy";
---
<section class="hero relative px-6 sm:px-10 pt-32 sm:pt-40 pb-24 sm:pb-32" id="hero">
  <div class="max-w-5xl mx-auto">
    <p class="font-mono text-eyebrow tracking-[0.2em] uppercase text-muted mb-10 sm:mb-14">
      {hero.eyebrow}
    </p>

    <h1 class="font-display text-[clamp(2rem,7vw,4.5rem)] leading-[1.05] tracking-[-0.02em] text-ink font-light">
      <span class="hero-line block">
        <span class="font-bold">Aivolvix</span> designs, builds,
      </span>
      <span class="hero-line block">and ships the brands</span>
      <span class="hero-line block">of <em class="italic font-normal">tomorrow.</em></span>
    </h1>

    <p class="mt-10 sm:mt-14 max-w-xl text-body text-base sm:text-lg leading-[1.6]">
      {hero.body}
    </p>
  </div>

  <!-- Subtle parallax — JS in Phase 4 -->
</section>

<script>
  const hero = document.querySelector<HTMLElement>(".hero");
  const isDesktop = window.matchMedia("(min-width: 1024px)").matches;
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (hero && isDesktop && !reduced) {
    const heading = hero.querySelector<HTMLElement>("h1");
    if (heading) {
      const onMove = (e: MouseEvent) => {
        const rect = hero.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        heading.style.transform = `translate(${x * 6}px, ${y * 6}px)`;
      };
      const onLeave = () => {
        heading.style.transform = "";
      };
      hero.addEventListener("mousemove", onMove);
      hero.addEventListener("mouseleave", onLeave);
    }
  }
</script>
