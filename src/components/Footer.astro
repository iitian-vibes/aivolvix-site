---
import { footer } from "../content/copy";
---
<footer class="bg-ink text-bone px-6 sm:px-10 py-14 sm:py-16">
  <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8 text-sm leading-[1.7]">
    <div>
      <p class="font-display text-lg font-bold text-bone mb-2">{footer.company}</p>
      <p class="text-bone/70">{footer.registration}</p>
      <p class="text-bone/70">{footer.directors}</p>
    </div>
    <div>
      <p class="font-mono text-eyebrow tracking-[0.2em] uppercase text-bone/60 mb-3">Contact</p>
      <a
        href={`mailto:${footer.email}`}
        class="text-bone hover:text-accent-gold transition-colors"
      >
        {footer.email}
      </a>
    </div>
    <div>
      <p class="font-mono text-eyebrow tracking-[0.2em] uppercase text-bone/60 mb-3">More</p>
      <ul class="space-y-1">
        {footer.links.map((l) => (
          <li><a href={l.href} class="text-bone hover:text-accent-gold transition-colors">{l.name}</a></li>
        ))}
      </ul>
    </div>
  </div>
  <div class="max-w-5xl mx-auto mt-10 pt-6 border-t border-bone/10 text-bone/50 text-xs font-mono uppercase tracking-[0.15em]">
    © {footer.year} {footer.company}
  </div>
</footer>
