---
import { work } from "../content/copy";
---
<section class="px-6 sm:px-10 py-20 sm:py-28 border-t border-rule" id="work">
  <div class="max-w-3xl mx-auto">
    <div class="reveal" data-reveal>
      <p class="font-mono text-eyebrow tracking-[0.2em] uppercase text-muted mb-3">
        03 — {work.eyebrow}
      </p>
      <h2 class="font-display text-[clamp(1.75rem,4.5vw,2.5rem)] leading-[1.1] tracking-[-0.02em] text-ink font-bold mb-10 sm:mb-12">
        {work.display}
      </h2>
    </div>

    <div class="space-y-10 max-w-2xl">
      {work.brands.map((b) => (
        <div>
          <p class="font-mono text-eyebrow tracking-[0.2em] uppercase text-accent-gold mb-2">
            {b.url}
          </p>
          <h3 class="font-display text-xl sm:text-2xl font-bold text-ink leading-tight mb-3">
            {b.name}
          </h3>
          <p class="text-body text-base sm:text-lg leading-[1.7]">
            {b.paragraph}
          </p>
        </div>
      ))}

      <p class="text-body text-base sm:text-lg leading-[1.7] pt-6 border-t border-rule italic">
        {work.closing}
      </p>
    </div>
  </div>
</section>
