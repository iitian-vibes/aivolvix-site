---
import { numbers } from "../content/copy";
import Reveal from "./Reveal.tsx";
---
<section class="px-6 sm:px-10 py-20 sm:py-28 border-t border-rule" id="numbers">
  <div class="max-w-5xl mx-auto">
    <Reveal client:visible>
      <p class="font-mono text-eyebrow tracking-[0.2em] uppercase text-muted mb-3">
        05 — {numbers.eyebrow}
      </p>
      <h2 class="font-display text-[clamp(1.75rem,4.5vw,2.5rem)] leading-[1.1] tracking-[-0.02em] text-ink mb-12 sm:mb-16">
        <em class="italic font-normal">Receipts.</em>
      </h2>
    </Reveal>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6" id="numbers-grid">
      {numbers.stats.map((s) => {
        const finalText = `${s.animateTo}${s.suffix ?? ""}`;
        return (
          <div class="bg-card border border-rule rounded-xl p-6 sm:p-8 text-center">
            <p class="font-display text-4xl sm:text-5xl font-bold text-ink leading-none tracking-tight">
              <span
                aria-hidden="true"
                data-count-target={s.animateTo}
                data-count-suffix={s.suffix ?? ""}
              >
                {finalText}
              </span>
              <span class="sr-only">{finalText}</span>
            </p>
            <p class="mt-3 font-mono text-eyebrow tracking-[0.2em] uppercase text-muted">
              {s.label}
            </p>
          </div>
        );
      })}
    </div>
  </div>
</section>

<script>
  const grid = document.getElementById("numbers-grid");
  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const targets = grid?.querySelectorAll<HTMLElement>("[data-count-target]");

  // Tiny targets (≤5) animate visibly — for those we skip the count and just
  // hold the final value. This avoids a janky "0 → 1 → 2" over 800ms.
  const ANIMATE_THRESHOLD = 5;

  if (grid && targets && !reduced) {
    // Reset animatable targets to 0 so we have a starting state.
    targets.forEach((el) => {
      const target = parseInt(el.dataset.countTarget ?? "0", 10);
      if (target > ANIMATE_THRESHOLD) {
        el.textContent = `0${el.dataset.countSuffix ?? ""}`;
      }
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          targets.forEach((el) => {
            const target = parseInt(el.dataset.countTarget ?? "0", 10);
            const suffix = el.dataset.countSuffix ?? "";
            if (target <= ANIMATE_THRESHOLD) {
              el.textContent = `${target}${suffix}`;
              return;
            }
            const duration = 800;
            const start = performance.now();
            const animate = (now: number) => {
              const t = Math.min((now - start) / duration, 1);
              const eased = 1 - Math.pow(1 - t, 3);
              const value = Math.floor(target * eased);
              el.textContent = `${value}${suffix}`;
              if (t < 1) requestAnimationFrame(animate);
              else el.textContent = `${target}${suffix}`;
            };
            requestAnimationFrame(animate);
          });
          observer.unobserve(entry.target);
        });
      },
      { threshold: 0.4 }
    );
    observer.observe(grid);
  }
  // If reduced motion is on, the SSR markup already shows final values — no JS needed.
</script>
