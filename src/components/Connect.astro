---
import { connect } from "../content/copy";
---
<section class="px-6 sm:px-10 py-20 sm:py-28 border-t border-rule" id="connect">
  <div class="max-w-3xl mx-auto">
    <div class="reveal" data-reveal>
      <p class="font-mono text-eyebrow tracking-[0.2em] uppercase text-muted mb-3">
        06 — {connect.eyebrow}
      </p>
      <h2 class="font-display text-[clamp(1.75rem,5vw,3rem)] leading-[1.05] tracking-[-0.02em] text-ink font-light mb-10">
        For partnerships, press,
        <br />
        <span class="font-light">or to <em class="italic font-normal">say hi.</em></span>
      </h2>
    </div>

    <div class="flex flex-wrap items-center gap-x-4 gap-y-3">
      <a
        href={`mailto:${connect.email}`}
        class="inline-block font-display text-2xl sm:text-3xl text-accent-gold border-b-2 border-accent-gold pb-1 hover:text-ink hover:border-ink transition-colors"
      >
        {connect.email}
      </a>
      <button
        type="button"
        id="copy-email"
        data-email={connect.email}
        class="font-mono text-eyebrow tracking-[0.2em] uppercase text-muted border border-rule rounded-full px-4 py-2 hover:text-ink hover:border-ink transition-colors"
      >
        <span data-label="default">Copy</span>
        <span data-label="copied" class="hidden">Copied ✓</span>
      </button>
    </div>

    <script>
      const btn = document.getElementById("copy-email");
      if (btn) {
        btn.addEventListener("click", async () => {
          const email = btn.dataset.email ?? "";
          try {
            await navigator.clipboard.writeText(email);
          } catch {
            // Fallback: ancient browsers — select a temp textarea
            const ta = document.createElement("textarea");
            ta.value = email;
            ta.style.position = "fixed";
            ta.style.opacity = "0";
            document.body.appendChild(ta);
            ta.select();
            try { document.execCommand("copy"); } catch {}
            document.body.removeChild(ta);
          }
          const def = btn.querySelector<HTMLElement>('[data-label="default"]');
          const ok = btn.querySelector<HTMLElement>('[data-label="copied"]');
          if (def && ok) {
            def.classList.add("hidden");
            ok.classList.remove("hidden");
            setTimeout(() => {
              def.classList.remove("hidden");
              ok.classList.add("hidden");
            }, 1800);
          }
        });
      }
    </script>

    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-xl">
      {connect.brandSocials.map((b) => (
        <div>
          <p class="font-mono text-eyebrow tracking-[0.2em] uppercase text-muted mb-2">
            Follow {b.brand}
          </p>
          <p class="text-body">
            {b.links.map((l, i) => (
              <span>
                {i > 0 && <span class="text-muted"> · </span>}
                <a
                  href={l.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-ink hover:text-accent-gold transition-colors"
                >
                  {l.name}
                </a>
              </span>
            ))}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
